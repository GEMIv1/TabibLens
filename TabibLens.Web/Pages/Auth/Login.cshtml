@page
@model TabibLens.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LoginLayout";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-logo">
            <h1>Welcome Back</h1>
            <p>Sign in to TabibLens to manage prescriptions</p>
        </div>

        @if (!ModelState.IsValid)
        {
            <div class="auth-error">
                <div asp-validation-summary="All" class="text-danger" style="margin-left: 8px;"></div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="auth-error" style="margin-bottom: 20px;">
                <div style="margin-left: 8px;">@TempData["ErrorMessage"]</div>
            </div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast-success" style="padding: 12px; border-radius: 8px; margin-bottom: 20px;">
                @TempData["SuccessMessage"]
            </div>
        }

        <form method="post" novalidate>
            <div class="form-group">
                <label asp-for="Input.Email" class="form-label">Email Address</label>
                <input asp-for="Input.Email" class="form-input" autofocus />
                <span asp-validation-for="Input.Email" class="form-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <input asp-for="Input.Password" class="form-input" type="password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="form-error"></span>
            </div>

            <button type="submit" class="btn btn-primary w-full btn-lg mt-sm">Sign In</button>
        </form>

        <div class="auth-footer">
            Don't have an account? <a asp-page="./Register">Register here</a>
        </div>
    </div>
</div>

@section Scripts {
}
